{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Songwriter",
  "version": "0.1.0",
  "identifier": "com.songwriter.app",
  "build": {
    "frontendDist": "../out-stub",
    "devUrl": "http://localhost:3737",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Songwriter",
        "url": "http://localhost:3737",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
